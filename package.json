{
  "name": "cross-recorder",
  "version": "0.11.1",
  "description": "Cross-platform desktop audio recorder built with Electrobun",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:native": "bash scripts/build-native.sh",
    "build": "bash scripts/ci-free-disk.sh && bash scripts/build-native.sh && vite build && electrobun build --env=stable",
    "build:vite": "vite build",
    "typecheck": "bash -c 'tsc --noEmit --skipLibCheck 2>&1 | grep -v node_modules | grep error && exit 1 || exit 0'",
    "lint": "oxlint -c oxlint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxlint --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.20.0",
    "electrobun": "^1.14.4",
    "framer-motion": "^12.35.1",
    "nanoid": "^5.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "oxlint": "^1.50.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
