{
  "name": "cross-recorder",
  "version": "0.13.0",
  "description": "Cross-platform desktop audio recorder built with Electrobun",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "bash scripts/build-native.sh && electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:native": "bash scripts/build-native.sh",
    "build": "bash scripts/ci-free-disk.sh && bash scripts/build-native.sh && vite build && electrobun build --env=stable",
    "build:vite": "vite build",
    "typecheck": "bash -c 'tsc --noEmit --skipLibCheck 2>&1 | grep -v node_modules | grep error && exit 1 || exit 0'",
    "lint": "oxlint -c oxlint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxlint --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.3",
    "electrobun": "^1.18.1",
    "framer-motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "overrides": {
      "picomatch@<2.3.2": "^2.3.2"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
